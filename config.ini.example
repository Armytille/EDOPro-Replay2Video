# EDOPro Replay2Video - Configuration File
# Rename to config.ini and place next to ygopro.exe (or in --workdir).
# CLI flags override these values when both are specified.

# Working directory: path to your EDOPro installation.
# Must contain: config/strings.conf, pics/, textures/, skin/, fonts/
workdir=D:\ProjectIgnis

# Output resolution.
resolution=1920x1080

# Target frame rate.
fps=60

# Video codec.
#   libx264    = software H.264, compatible everywhere
#   h264_nvenc = NVIDIA GPU H.264, fast
#   av1_nvenc  = NVIDIA GPU AV1, best quality/size ratio (RTX 30xx+)
#   libx265    = software HEVC, smaller files, very slow
codec=av1_nvenc

# Encoding preset.
# NVENC presets: p1 (fastest) to p7 (best quality)
# x264/x265 presets: ultrafast veryfast medium slow veryslow
preset=p7

# Constant Rate Factor. 0 = lossless, higher = more compression.
# av1_nvenc: 0 (lossless) recommended for archival quality
# libx264:   18 (near-lossless) to 23 (default)
crf=0

# Encoder tune (optional).
# NVENC: hq, ll (low latency), ull, lossless
# x264/x265: film, animation, grain
tune=hq

# Scaling algorithm for resolution conversion.
#   bilinear  - fast
#   lanczos   - sharper, better quality
scale_filter=lanczos

# POV player. 0 = player 1 (bottom), 1 = player 2 (top).
player=0

# Background margin as a fraction of width (0.0 to 0.45).
# 0.10 = 10% black margin each side.
margin=0.10

# Playback speed multiplier. 1.0 = normal, 1.5 = 50% faster.
speed=1.0

# Fixed bitrate override in kbps (optional). Overrides crf if set.
# bitrate=8000

# FFmpeg video filter string (optional).
# vf=libplacebo=upscaler=ewa_lanczos:antiringing=1

# Hardware acceleration for video filters (optional).
# hwaccel=vulkan
# hwaccel_device=0
