+		// full width = window_size.Width, full height = window_size.Height.
+		const irr::s32 sw = (irr::s32)window_size.Width;
+		const irr::s32 sh = (irr::s32)window_size.Height;
+		// Bar width: field content occupies tight_half_w/cam_right of screen width.
+		// tight_half_w=0.4472 (fixed field NDC half-width), cam_right = half_h * pixel_ratio.
+		// LP bars span the visible field width. The field's horizontal NDC extent
+		// at zero margin is tight_half_w=0.4472. cam_right includes the margin.
+		// We scale down further by 0.85 to leave some breathing room on the sides.
+		const float tight_half_w = 0.4472f * 0.75f;
+		const float tight_half_h = 0.2850f;
+		const float cam_right = (cfg.cam_right > 0.0f) ? cfg.cam_right
+		                      : tight_half_h * ((float)sw / (float)sh);
+		const irr::s32 bar_w = (irr::s32)(sw * tight_half_w / cam_right);
+		const irr::s32 bar_x0 = (sw - bar_w) / 2;
+		const irr::s32 bar_x1 = bar_x0 + bar_w;
+		// Bar height: slim, fits numFont LP text (~16px scaled)
+		const irr::s32 bar_h = std::max(14, (irr::s32)(sh * 0.020f));
+		r2v_bar_y0 = 0;
+		r2v_bar_y1 = r2v_bar_y0 + bar_h;
+		// Turn counter: fixed-width rect centered on screen, sized to fit lpcFont digits (48px).
