+// Shared geometry: returns the logical-space scale factor used to grow the
+// native deck builder layout (487×493) into the freed area (717×632). Called
+// from both the renderer and the gframe.cpp startup so SetArtTextureSize can
+// size the cached ART texture to match the on-screen thumb dimensions.
+float Game::GetDeckBdR2VScale() {
+	const int native_body_w     = 487;
+	const int native_header_h   = 23;
+	const int native_main_body  = 276;
+	const int native_extra_body = 70;
+	const int native_side_body  = 70;
+	const int native_body_total = native_main_body + native_extra_body + native_side_body;
+	const int avail_w = 1022 - 305;   // 717
+	const int avail_h = 638 - 6;      // 632
+	const int gap     = 4;
+	const int fixed_y_overhead = 2 * gap + 3 * 3;
+	const float scale_x = (float)avail_w / (float)native_body_w;
+	const float scale_y = (float)(avail_h - fixed_y_overhead)
+	                    / (float)(3 * native_header_h + native_body_total);
+	return std::min(scale_x, scale_y);
+}
+// Deck export rendering. Differences vs DrawDeckBd():
