+		// right side when they overlap — meaning the visible right edge of card i
+		// is the LEFT edge of card i+1. Clamp the highlight to that visible bound
+		// so it doesn't overdraw onto card i+1. Left side needs no clamp because
+		// card i is drawn on top of card i-1, so its left edge is fully visible.
+		irr::core::recti highlight_rect;
+		int neighbour_right_left_edge = INT_MAX;  // left edge of card i+1 (same row), in screen coords
+		bool has_highlight = false;
+		for(int i = 0; i < (int)cards.size(); ++i) {
+			const int col = i % per_row;
+			const int row = i / per_row;
+			// Round (not truncate) and pin width/height to tw/th so the on-screen
+			// rect always matches the cached scaled-texture dimensions — avoids a
+			// 1px blurry edge from sub-pixel GPU sampling.
+			const int x = (int)std::lround((float)inner_l + col * dx);
+			const int y = (int)std::lround((float)body_top + 4.0f + row * dy);
+			irr::core::recti rect = Resize(x, y, x + tw, y + th);
+			// Source: ART (1024px texture set via SetArtTextureSize). Render via
+			// draw2DImageFilterScaled — Irrlicht's high-quality cached software
+			// downscaler — instead of raw draw2DImage which uses point/bilinear
+			// GPU sampling and produces a mushy result at this scale ratio.
+			auto img = imageManager.GetTextureCard(cards[i]->code, imgType::ART, false, true);
+			if(img) {
+				irr::core::dimension2du sz = img->getOriginalSize();
+				imageManager.draw2DImageFilterScaled(img, rect,
+				                                    irr::core::recti(0, 0, sz.Width, sz.Height),
+				                                    nullptr, nullptr, true);
+			}
+			if(section_pos == cur_pos && i == cur_seq) {
+				highlight_rect = rect;
+				has_highlight = true;
+			}
+			if(section_pos == cur_pos && i == cur_seq + 1 && row == (cur_seq / per_row))
+				neighbour_right_left_edge = rect.UpperLeftCorner.X;
+		}
+		if(has_highlight) {
+			// Inflate by 2px in screen space, reusing the card's exact Resize() rect
+			// so the outline is pixel-aligned with the card edge (no sub-pixel drift).
+			irr::core::recti hl = highlight_rect;
+			hl.UpperLeftCorner.X  -= 2;
+			hl.UpperLeftCorner.Y  -= 2;
+			hl.LowerRightCorner.X += 2;
+			hl.LowerRightCorner.Y += 2;
+			if(hl.LowerRightCorner.X > neighbour_right_left_edge) hl.LowerRightCorner.X = neighbour_right_left_edge;
+			irr::core::recti hl2 = hl;
+			hl2.UpperLeftCorner.X  += 1; hl2.UpperLeftCorner.Y  += 1;
+			hl2.LowerRightCorner.X -= 1; hl2.LowerRightCorner.Y -= 1;
+			driver->draw2DRectangleOutline(hl,  0xffffff00);
+			driver->draw2DRectangleOutline(hl2, 0xffffff00);
+		}
+	};
+
+	int y = top;
+	draw_section(y, main_body_h, 1, current_deck.main,
+	             gDataManager->GetSysString(1330).data(),
+	             epro::to_wstring(current_deck.main.size()), 10);
+	y += header_h + 3 + main_body_h + gap_extra;
+	draw_section(y, extra_body_h, 2, current_deck.extra,
+	             gDataManager->GetSysString(1331).data(),
+	             epro::to_wstring(current_deck.extra.size()), 10);
+	y += header_h + 3 + extra_body_h + gap_side;
+	draw_section(y, side_body_h, 3, current_deck.side,
+	             gDataManager->GetSysString(1332).data(),
+	             epro::to_wstring(current_deck.side.size()), 10);
+}
+#endif // WITH_REPLAY2VIDEO
 #undef DRAWRECT
 #undef DECKCOLOR
 #undef SKCOLOR
