 void Game::WaitFrameSignal(int frame, std::unique_lock<epro::mutex>& _lck) {
+#ifdef WITH_REPLAY2VIDEO
+	if(replay2video::g_batch.active) {
+		signalFrame = static_cast<uint32_t>(frame * 1000 / 60 / replay2video::g_batch.config.speed);
+		return; // MainLoop decrements signalFrame; StepBatch won't run until it hits 0
+	}
+#endif
 	signalFrame = (gGameConfig->quick_animation && frame >= 12) ? 12 * 1000 / 60 : frame * 1000 / 60;
 	frameSignal.Wait(_lck);
 }
