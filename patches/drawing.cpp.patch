+		const irr::s32 turn_half_w = std::max(40, (irr::s32)(sh * 0.075f));
+		const irr::s32 cx = sw / 2;
+		r2v_turn_x0 = cx - turn_half_w;
+		r2v_turn_x1 = cx + turn_half_w;
