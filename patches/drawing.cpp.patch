+	//   - Extra section: body 310..797 × 463..533 → 487×70.
+	//                    dx = 436/9 (≤10 cards) else 436/(n-1). dy n/a (single row).
+	//   - Side section:  body 310..797 × 560..630 → 487×70 (same layout as extra).
+	//
+	// Deck export available area (no UI overlays):
+	//   - inner_w = 1018 - 309 - 8 = 709 (vs native 487+4*2-8 = 483) → x-scale 1.467
+	//   - vertical: we want sections to fill y=6..632 (height 626) instead of native
+	//     y=137..630 (height 493). y-scale = 626/493 = 1.270.
+	//   - Uniform scale = min(x-scale, y-scale) = 1.270 (height-limited).
+	const auto& current_deck = deckBuilder.GetCurrentDeck();
+
+	const int left = 305;
+	const int right = 1022;
+	const int top  = 6;
+	const int cur_pos = replay2video::g_batch.deck_index_pos;
+	const int cur_seq = replay2video::g_batch.deck_index_seq;
+
+	// Native widths and heights for the body rectangles (the only spec that matters
+	// for the card grid is the body, since headers are decorative).
+	const int native_main_body_h  = 276; // 436 - 160
+	const int native_extra_body_h = 70;  // 533 - 463
+	const int native_side_body_h  = 70;  // 630 - 560
+	const int native_body_w       = 487; // 797 - 310
+	const int native_header_h = 23;       // 160 - 137
