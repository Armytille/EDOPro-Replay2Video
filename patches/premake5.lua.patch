+	excludes { "lzma/**", "SoundBackends/**", "sfAudio/**", "Android/**", "replay2video/**" }
+
+	if _OPTIONS["with-replay2video"] then
+		files { "replay2video/**.cpp", "replay2video/**.h" }
+		defines "WITH_REPLAY2VIDEO"
+	end
+
 	if _OPTIONS["oldwindows"] then
 		filter {'action:vs*'}
 			files { "../overwrites/overwrites.cpp", "../overwrites/loader.asm" }
@@ -243,6 +255,14 @@ local ygopro_config=function(static_core)
 			links "secur32"
 		end
 
+		if _OPTIONS["with-replay2video"] then
+			filter "system:windows"
+				_includedirs { os.getenv("FFMPEG_DEV") .. "/include" }
+				libdirs { os.getenv("FFMPEG_DEV") .. "/lib" }
+			filter {}
+			links { "avcodec", "avformat", "avutil", "swscale", "swresample" }
+		end
+
 	if static_core then
 		filter {}
