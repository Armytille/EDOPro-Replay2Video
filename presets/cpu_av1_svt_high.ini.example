# CPU AV1 SVT - High quality (near-lossless, very slow render)
# Requires a modern player (VLC, mpv, recent browsers). AV1 not universally supported.
# SVT-AV1 preset: 0=slowest/best, 13=fastest. Preset 4 for high quality at reasonable speed.
# Note: libplacebo on CPU is slow — expect very long render times.
# Rename to config.ini and place next to replay2video.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=libsvtav1
preset=4
crf=20
scale_filter=lanczos
vf=libplacebo=upscaler=ewa_lanczos:downscaler=ewa_lanczos:antiringing=1:deband=1:deband_iterations=4:deband_radius=24:deband_threshold=4:chroma_location=left
margin=0.10
speed=1.0
film_grain=20
hwaccel=vulkan
