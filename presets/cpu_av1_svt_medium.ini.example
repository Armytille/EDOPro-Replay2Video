# CPU AV1 SVT - Medium quality (balanced speed/quality, excellent compression)
# Requires a modern player (VLC, mpv, recent browsers). AV1 not universally supported.
# SVT-AV1 preset: 0=slowest/best, 13=fastest. Preset 8 is the recommended default.
# Rename to config.ini and place next to replay2video.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=libsvtav1
preset=8
crf=28
scale_filter=lanczos
margin=0.10
speed=1.0
