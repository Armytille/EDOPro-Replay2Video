# CPU H.264 - High quality (near-lossless, slow render)
# Compatible with every player and platform.
# Note: libplacebo on CPU is slow — expect long render times.
# Rename to config.ini and place next to replay2video.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=libx264
preset=slow
crf=18
tune=film
scale_filter=lanczos
vf=libplacebo=upscaler=ewa_lanczos:downscaler=ewa_lanczos:antiringing=1:deband=1
margin=0.10
speed=1.0
