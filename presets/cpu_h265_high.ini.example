# CPU H.265/HEVC - High quality (excellent compression, very slow render)
# Requires a modern player (VLC, mpv, recent browsers).
# Note: libplacebo on CPU is slow — expect very long render times.
# Rename to config.ini and place next to ygopro.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=libx265
preset=slow
crf=20
tune=grain
scale_filter=lanczos
vf=libplacebo=upscaler=ewa_lanczos:downscaler=ewa_lanczos:antiringing=1:deband=1
margin=0.10
speed=1.0
