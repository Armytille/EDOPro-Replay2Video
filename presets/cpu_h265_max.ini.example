# CPU H.265/HEVC - Max quality (near-lossless, extremely slow render)
# Requires a modern player (VLC, mpv, recent browsers).
# Note: libplacebo on CPU is slow — expect extremely long render times.
# Rename to config.ini and place next to replay2video.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=libx265
preset=veryslow
crf=16
tune=grain
scale_filter=lanczos
vf=libplacebo=upscaler=ewa_lanczos:downscaler=ewa_lanczos:antiringing=1:deband=1:dither=error_diffusion
margin=0.10
speed=1.0
