# GPU AV1 NVENC - Max quality (best quality/size ratio, archival)
# Requires NVIDIA RTX 40xx with Vulkan. AV1 not supported on all players (use VLC/mpv).
# Rename to config.ini and place next to ygopro.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=av1_nvenc
preset=p7
crf=1
scale_filter=lanczos
vf=libplacebo=upscaler=ewa_lanczos:downscaler=ewa_lanczos:antiringing=1:deband=1
hwaccel=vulkan
margin=0.10
speed=1.0
