# GPU AV1 NVENC - Medium quality (fast GPU render, excellent compression)
# Requires NVIDIA RTX 40xx. AV1 not supported on all players (use VLC/mpv).
# Rename to config.ini and place next to ygopro.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=av1_nvenc
preset=p4
crf=20
scale_filter=lanczos
margin=0.10
speed=1.0
