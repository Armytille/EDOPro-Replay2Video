# GPU H.264 NVENC - Low quality (fastest GPU render, small file)
# Requires NVIDIA GPU. Compatible with every player.
# Rename to config.ini and place next to ygopro.exe.

workdir=D:\ProjectIgnis
resolution=1280x720
fps=30
codec=h264_nvenc
preset=p1
crf=32
scale_filter=bilinear
margin=0.10
speed=1.0
