# GPU HEVC NVENC - Max quality (best NVENC HEVC quality, GPU post-processing)
# Requires NVIDIA GPU (GTX 10xx+) with Vulkan support. Requires modern player.
# Rename to config.ini and place next to replay2video.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=hevc_nvenc
preset=p7
crf=14
scale_filter=lanczos
vf=libplacebo=upscaler=ewa_lanczos:downscaler=ewa_lanczos:antiringing=1:deband=1:dither=error_diffusion
hwaccel=vulkan
margin=0.10
speed=1.0
