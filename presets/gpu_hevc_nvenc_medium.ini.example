# GPU HEVC NVENC - Medium quality (fast GPU render, good compression)
# Requires NVIDIA GPU (GTX 10xx+). Better than H.264, requires modern player.
# Rename to config.ini and place next to ygopro.exe.

workdir=D:\ProjectIgnis
resolution=1920x1080
fps=60
codec=hevc_nvenc
preset=p4
crf=23
scale_filter=lanczos
margin=0.10
speed=1.0
